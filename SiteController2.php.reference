    // Обработка входящих запросов через бота
    public function botHandler (Request $request) {

        define('BOT_TOKEN', '6858938442:AAEjaDjtUBVgiUr7M2ylEsHH4a3nXhaKLGo');
        define('API_URL', 'https://api.telegram.org/bot'.BOT_TOKEN.'/');

        date_default_timezone_set('Europe/Moscow');


//        $resp = file_get_contents("https://api.telegram.org/bot".BOT_TOKEN."/sendMessage?" . http_build_query(hhhhh) );


        // Получаем данные по последнему запросу апдейтов от ТГ
        $last_update = DB::table('telegram_updates')
        ->orderBy('id', 'DESC')
        ->first();

        if ($last_update) {
            $offset = $last_update->update_id + 1;
        } else {
            $offset = 0;
        }

        $response = file_get_contents("https://api.telegram.org/bot".BOT_TOKEN."/getUpdates?offset=".$offset );
        $response = json_decode($response, true);

        $admins = [
            '810564487' , // Alex
            '1098521522' // Spartak
        ];

        foreach ($response['result'] as $update) {
            //echo $update['update_id'] . '<br>';
            //echo $update['message']['from']['id'] . '<br>';
            //echo $update['message']['text'] . '<br>';
            // Сначала записываем всё, что прилетело от ТГ в базу
            DB::table('telegram_updates')->insert(['update_id' => $update['update_id'], 'update_json' => json_encode($update), 'created_at' => NOW()]);
            // Теперь проверяем, что id автора сообщения есть в массиве разрешенных
            if (in_array($update['message']['from']['id'], $admins)) {
                // Теперь парсим сообщение
                if (strpos($update['message']['text'], '/cancel') !== false) {
                    $order_id = intval(str_replace("/cancel", "", $update['message']['text']));
                    if (isset($order_id) && $order_id > 0) {
                        // Сначала ищем существует ли такой заказ
                        $order = DB::table('room_orders')
                        ->where('id', $order_id)
                        ->first();
                        if ($order) {
                            if ($order->status == "booked" OR $order->status == "new") {
                                DB::table('room_orders')
                                ->where('id', $order->id)
                                ->update([
                                    'status' => "cancelled",
                                    'updated_at' => now()
                                ]);
                                DB::table('room_order_times')
                                ->where('order_id', $order->id)
                                ->update([
                                    'active' => 0,
                                    'updated_at' => now()
                                ]);
                                $msg = "Бронирование #*".$order_id."* успешно *ОТМЕНЕНО*.";
                            }
                            if ($order->status == "cancelled") {
                                $msg = "Бронирование #*".$order_id."* уже имеет статус *ОТМЕНЕНО*.";
                            }
                        } else {
                            $msg = "Бронирования с id ".$order_id." не найдено.";
                        }

                        foreach ($admins as $a) {
                            $data = [
                                'chat_id' => $a,
                                'text' => $msg,
                                'parse_mode' => 'markdown'
                            ];
                            $response = file_get_contents("https://api.telegram.org/bot".BOT_TOKEN."/sendMessage?" . http_build_query($data) );
                        }

                    }
                }
            }
        }



    }

