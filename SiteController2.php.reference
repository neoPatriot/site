    public function edit_room_action(Request $request)
    {

        if (Auth::guest()) {
            return redirect('/z-login');
        }

        // Устанавливаем время по Мск
        date_default_timezone_set('Europe/Moscow');

        $request->validate([
            'room_id' => 'integer'
        ]);

        // Проверяем, что комната существует
        if (room::where('id', $request->room_id)->count() == 0) {
            return back()->with('fail', 'Такой комнаты не существует!');
        }

        $times = [
            '00:00-01:00',
            '01:00-02:00',
            '02:00-03:00',
            '03:00-04:00',
            '04:00-05:00',
            '05:00-06:00',
            '06:00-07:00',
            '07:00-08:00',
            '08:00-09:00',
            '09:00-10:00',
            '10:00-11:00',
            '11:00-12:00',
            '12:00-13:00',
            '13:00-14:00',
            '14:00-15:00',
            '15:00-16:00',
            '16:00-17:00',
            '17:00-18:00',
            '18:00-19:00',
            '19:00-20:00',
            '20:00-21:00',
            '21:00-22:00',
            '22:00-23:00',
            '23:00-24:00',
        ];

        $intervals = [];

        // Проверяем входящие данные и собираем в массив
        for ($d = 1; $d <=7; $d++) {
            foreach ($times as $time) {
                $interval = $d . '-' . $time;
                $intervals[$interval] = $request->$interval;
            }
        }

        $intervals_json = json_encode($intervals);

        room_schedule::where('room_id', $request->room_id)
        ->update(['schedule' => $intervals_json]);

        return back()->with('message', 'Расписание успешно отредактировано!');

    }








