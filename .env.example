# This is an example file. Copy it to .env and fill in your actual values.
# DO NOT commit the .env file to version control.

# Django Settings
# Generate a new secret key for production. You can use an online generator.
SECRET_KEY=your-super-secret-key-goes-here
# Set to False in production
DEBUG=False

# Telegram Bot Settings
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_IDS=chat_id1,chat_id2,chat_id3

# Database URL (if using PostgreSQL/MySQL in the future)
# DATABASE_URL=postgres://user:password@host:port/dbname
